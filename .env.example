# ── Backend (required) ────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string
DATABASE_URL=postgresql://postgres:password@project-db-1:5432/postgres
COGNITO_USER_POOL_ID=ap-southeast-1_XXXXXXXXX
COGNITO_CLIENT_ID=your-cognito-client-id
COGNITO_DOMAIN=your-app.auth.ap-southeast-1.amazoncognito.com
COGNITO_REDIRECT_URI=https://your-domain.com/auth/callback

# ── Backend (optional) ───────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
COGNITO_CLIENT_SECRET=
FRONTEND_URL=https://your-domain.com
DEBUG=false

# ── Frontend (build-time) ────────────────────────────────
VITE_API_URL=https://api.your-domain.com
VITE_COGNITO_DOMAIN=your-app.auth.ap-southeast-1.amazoncognito.com
VITE_COGNITO_CLIENT_ID=your-cognito-client-id
VITE_COGNITO_REDIRECT_URI=https://your-domain.com/auth/callback
